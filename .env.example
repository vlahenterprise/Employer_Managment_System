DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/employer
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional (comma-separated): only allow these email domains
AUTH_ALLOWED_EMAIL_DOMAINS=

# Optional: allow Google SSO to auto-create users (default: false)
AUTH_AUTO_PROVISION=false

# Optional: Google Workspace SSO (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: seed admin (run `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=
