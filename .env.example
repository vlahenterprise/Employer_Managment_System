# Neon pooled runtime connection (recommended on Vercel / serverless).
# Example:
# postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=15&connect_timeout=15
DATABASE_URL=

# Direct Neon connection for Prisma CLI and migrations.
# Example:
# postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&connect_timeout=15
DIRECT_URL=

NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Required for protected Vercel cron backup route.
CRON_SECRET=

# Optional (comma-separated): only allow these email domains
AUTH_ALLOWED_EMAIL_DOMAINS=

# Optional: allow Google SSO to auto-create users (default: false)
AUTH_AUTO_PROVISION=false

# Optional: Google Workspace SSO (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: CV upload hardening (bytes). Prefer Google Drive URLs over DB uploads.
CV_MAX_UPLOAD_BYTES=5242880

# Optional: lightweight per-user rate limiting for expensive exports.
PDF_ROUTE_LIMIT_PER_MINUTE=10
BACKUP_ROUTE_LIMIT_PER_MINUTE=4

# Upstash Redis za distribuirani rate limiting (opciono, preporučeno za produkciju)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override Chromium runtime behavior for PDF generation.
PDF_RENDER_TIMEOUT_MS=12000
CHROMIUM_EXECUTABLE_PATH=
CHROMIUM_PACK_URL=

# Feature flags
ENABLE_HR_MODULE=true

# Enkripcija osetljivih polja u bazi (opciono, preporučeno za produkciju).
# Mora biti 64-char hex string (32 bajta). Generiši: openssl rand -hex 32
# VAŽNO: Nikad ne stavljaj pravi ključ ovde — samo u Vercel env / lokalni .env
FIELD_ENCRYPTION_KEY=

# Opcioni rate limit za login (default: 10 pokušaja / 10 min po email-u)
LOGIN_RATE_LIMIT_PER_10_MIN=10

# Optional: Google Workspace Calendar/Gmail integration.
# Secrets stay in Vercel/local env only; do not commit real values.
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=
GOOGLE_WORKSPACE_BOT_EMAIL=internal@draganvlah.com
GOOGLE_WORKSPACE_CALENDAR_ID=c_5f35dbee085585ae9042314882faca52feed47cef99d645a9d20f7c355474481@group.calendar.google.com
GOOGLE_WORKSPACE_EMAIL_ENABLED=true
GOOGLE_WORKSPACE_CALENDAR_ENABLED=true
GOOGLE_WORKSPACE_TASK_CALENDAR_ENABLED=true

# Optional: seed admin (run `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@company.com
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PASSWORD=
