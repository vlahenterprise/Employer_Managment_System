generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  HR
  MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TaskPriority {
  LOW
  MED
  HIGH
  CRIT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  FOR_APPROVAL
  RETURNED
  APPROVED
  CANCELLED
}

enum AbsenceType {
  ANNUAL_LEAVE
  HOME_OFFICE
  SLAVA
  OTHER
  SICK
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EvaluationStatus {
  OPEN
  SELF_SUBMITTED
  CLOSED
  CANCELLED
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  activityTypes ActivityType[]
  tasks     Task[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  name        String
  position    String?
  image       String?
  emailVerified DateTime?
  passwordHash String?
  role        UserRole   @default(USER)
  status      UserStatus @default(ACTIVE)
  carryOverAnnualLeave Int @default(0)
  annualLeaveDays Int?
  homeOfficeDays Int?
  slavaDays Int?
  teamId      String?
  team        Team?      @relation(fields: [teamId], references: [id])
  managerId   String?
  manager     User?      @relation("ManagerUsers", fields: [managerId], references: [id])
  reports     User[]     @relation("ManagerUsers")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  accounts  Account[]
  sessions  Session[]

  tasksAssigned   Task[]   @relation("TaskAssignee")
  tasksDelegated  Task[]   @relation("TaskDelegator")
  taskComments    TaskComment[]
  taskEvents      TaskEvent[]
  absences        Absence[] @relation("EmployeeAbsences")
  absencesApproved Absence[] @relation("ApproverAbsences")
  absenceEvents   AbsenceEvent[]
  dailyReports    DailyReport[]
  evaluations     PerformanceEvaluation[] @relation("EmployeeEvaluations")
  reviewsGiven    PerformanceEvaluation[] @relation("ManagerEvaluations")
  evaluationsLocked PerformanceEvaluation[] @relation("LockedByEvaluations")
  performanceLogs PerformanceLog[]
  orgAssignments OrgPositionAssignment[]

  @@index([managerId])
  @@index([teamId])
}

model OrgPosition {
  id          String   @id @default(cuid())
  title       String
  description String?
  parentId    String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    OrgPosition? @relation("OrgPositionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrgPosition[] @relation("OrgPositionTree")
  links     OrgPositionLink[]
  assignees OrgPositionAssignment[]

  @@index([parentId])
  @@index([order])
  @@index([isActive])
}

model OrgPositionAssignment {
  id         String   @id @default(cuid())
  positionId String
  userId     String
  createdAt  DateTime @default(now())

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([positionId, userId])
  @@index([userId])
}

model OrgPositionLink {
  id         String   @id @default(cuid())
  positionId String
  label      String
  url        String
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@index([order])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ActivityType {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, name])
  @@index([teamId])
  @@index([isActive])
}

model DailyReport {
  id            String   @id @default(cuid())
  userId        String
  dateIso       String
  employeeEmail String
  employeeName  String
  teamName      String
  position      String?
  week          Int
  month         Int
  year          Int
  totalMinutes  Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id])
  activities DailyReportActivity[]

  @@unique([userId, dateIso])
  @@index([dateIso])
  @@index([employeeEmail])
  @@index([teamName])
  @@index([position])
}

model DailyReportActivity {
  id        String   @id @default(cuid())
  reportId  String
  type      String
  desc      String
  minutes   Int
  createdAt DateTime @default(now())

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([type])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MED)
  status      TaskStatus   @default(OPEN)
  delegatorId String
  assigneeId  String
  teamId      String?
  delegatedAt DateTime     @default(now())
  dueDate     DateTime?
  forApprovalAt DateTime?
  approvedAt  DateTime?
  cancelledAt DateTime?
  returnedCount Int @default(0)
  employeeComment String?
  adminComment String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  delegator   User         @relation("TaskDelegator", fields: [delegatorId], references: [id])
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  events      TaskEvent[]

  @@index([assigneeId])
  @@index([delegatorId])
  @@index([status])
  @@index([priority])
  @@index([delegatedAt])
  @@index([dueDate])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  action    String
  actorId   String?
  actorEmail String
  actorName String
  comment   String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([createdAt])
  @@index([action])
}

model Absence {
  id         String        @id @default(cuid())
  employeeId String
  approverId String?
  type       AbsenceType
  status     AbsenceStatus @default(PENDING)
  dateFrom   DateTime
  dateTo     DateTime
  days       Int
  comment    String?
  overlapWarning Boolean @default(false)
  approvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  employee   User          @relation("EmployeeAbsences", fields: [employeeId], references: [id])
  approver   User?         @relation("ApproverAbsences", fields: [approverId], references: [id])
  events     AbsenceEvent[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([dateFrom])
  @@index([dateTo])
}

model AbsenceEvent {
  id        String   @id @default(cuid())
  absenceId String
  action    String
  actorId   String?
  actorEmail String
  actorName String
  comment   String?
  createdAt DateTime @default(now())

  absence   Absence  @relation(fields: [absenceId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([absenceId])
  @@index([createdAt])
  @@index([action])
}

model PerformanceEvaluation {
  id            String           @id @default(cuid())
  employeeId    String
  managerId     String
  periodStart   DateTime
  periodEnd     DateTime
  periodLabel   String
  status        EvaluationStatus @default(OPEN)
  locked        Boolean          @default(false)
  lockedAt      DateTime?
  lockedById    String?
  unlockOverride Boolean         @default(false)
  closedAt      DateTime?

  personalScore     Float?
  goalsScore        Float?
  finalScore        Float?
  managerFinalComment String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      User     @relation("EmployeeEvaluations", fields: [employeeId], references: [id])
  manager       User     @relation("ManagerEvaluations", fields: [managerId], references: [id])
  lockedBy      User?    @relation("LockedByEvaluations", fields: [lockedById], references: [id])
  goals         PerformanceGoal[]
  personalItems PerformancePersonalItem[]
  logs          PerformanceLog[]

  @@index([employeeId])
  @@index([managerId])
  @@index([status])
}

model PerformanceGoal {
  id              String  @id @default(cuid())
  evaluationId    String
  title           String
  description     String?
  weight          Float
  employeeScore   Float?
  employeeComment String?
  managerScore    Float?
  managerComment  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evaluation      PerformanceEvaluation @relation(fields: [evaluationId], references: [id])
  logs            PerformanceLog[]

  @@index([evaluationId])
}

model PerformanceQuestion {
  id          String   @id @default(cuid())
  qNo         Int      @unique
  area        String
  description String
  scale       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personalItems PerformancePersonalItem[]
}

model PerformancePersonalItem {
  id              String  @id @default(cuid())
  evaluationId    String
  questionId      String
  qNo             Int
  area            String
  description     String
  scale           String
  managerRating   Float?
  managerComment  String?
  updatedAt       DateTime @updatedAt

  evaluation      PerformanceEvaluation @relation(fields: [evaluationId], references: [id])
  question        PerformanceQuestion   @relation(fields: [questionId], references: [id])

  @@index([evaluationId])
  @@index([qNo])
}

model PerformanceLog {
  id           String   @id @default(cuid())
  evaluationId String
  goalId       String?
  actorId      String?
  actorEmail   String
  action       String
  field        String?
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())

  evaluation   PerformanceEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  goal         PerformanceGoal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  actor        User?                 @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([evaluationId])
  @@index([createdAt])
  @@index([action])
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
