generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  HR
  MANAGER
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TaskPriority {
  LOW
  MED
  HIGH
  CRIT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  FOR_APPROVAL
  RETURNED
  APPROVED
  CANCELLED
}

enum AbsenceType {
  ANNUAL_LEAVE
  HOME_OFFICE
  SLAVA
  OTHER
  SICK
}

enum AbsenceStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EvaluationStatus {
  OPEN
  SELF_SUBMITTED
  CLOSED
  CANCELLED
}

enum HrProcessStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  ON_HOLD
  APPROVED
  CLOSED
  CANCELED
}

enum HrCandidateStatus {
  NEW_APPLICANT
  HR_SCREENING
  REJECTED_BY_HR
  SENT_TO_MANAGER
  WAITING_MANAGER_REVIEW
  INTERVIEW_SCHEDULED
  SECOND_ROUND_COMPLETED
  REJECTED_BY_MANAGER
  WAITING_FINAL_APPROVAL
  APPROVED_FOR_EMPLOYMENT
  REJECTED_FINAL
  ARCHIVED
  CANCELED
}

enum HrPriority {
  LOW
  MED
  HIGH
  CRITICAL
}

enum OnboardingStatus {
  PLANNED
  ACTIVE
  WAITING_EMPLOYEE_ACTIONS
  WAITING_MANAGER_ACTIONS
  WAITING_HR_ACTIONS
  COMPLETED
}

enum OnboardingItemOwner {
  HR
  MANAGER
  EMPLOYEE
  SHARED
}

enum OrgLinkType {
  JOB_DESCRIPTION
  WORK_INSTRUCTIONS
  POSITION_PROCESS
  POSITION_INSTRUCTION
  GLOBAL_PROCESS
  GLOBAL_INSTRUCTION
}

enum OrgPositionTier {
  DIRECTOR
  MANAGER
  LEAD
  SUPERVISOR
  STAFF
}

enum OrgNodeKind {
  POSITION
  TEAM
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  orgPositions OrgPosition[]
  activityTypes ActivityType[]
  tasks     Task[]
  hrProcesses HrProcess[]
  onboardings Onboarding[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String     @id @default(cuid())
  email       String     @unique
  name        String
  position    String?
  image       String?
  emailVerified DateTime?
  passwordHash String?
  role        UserRole   @default(USER)
  hrAddon     Boolean    @default(false)
  adminAddon  Boolean    @default(false)
  status      UserStatus @default(ACTIVE)
  carryOverAnnualLeave Int @default(0)
  annualLeaveDays Int?
  homeOfficeDays Int?
  slavaDays Int?
  employmentDate DateTime?
  jobDescriptionUrl String?
  workInstructionsUrl String?
  teamId      String?
  team        Team?      @relation(fields: [teamId], references: [id])
  managerId   String?
  manager     User?      @relation("ManagerUsers", fields: [managerId], references: [id])
  reports     User[]     @relation("ManagerUsers")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  accounts  Account[]
  sessions  Session[]
  passwordResetTokens PasswordResetToken[]

  tasksAssigned   Task[]   @relation("TaskAssignee")
  tasksDelegated  Task[]   @relation("TaskDelegator")
  taskComments    TaskComment[]
  taskEvents      TaskEvent[]
  absences        Absence[] @relation("EmployeeAbsences")
  absencesApproved Absence[] @relation("ApproverAbsences")
  absenceEvents   AbsenceEvent[]
  dailyReports    DailyReport[]
  evaluations     PerformanceEvaluation[] @relation("EmployeeEvaluations")
  reviewsGiven    PerformanceEvaluation[] @relation("ManagerEvaluations")
  evaluationsLocked PerformanceEvaluation[] @relation("LockedByEvaluations")
  performanceLogs PerformanceLog[]
  orgAssignments OrgPositionAssignment[]
  hrProcessesOpened HrProcess[] @relation("HrProcessOpenedBy")
  hrProcessesManaged HrProcess[] @relation("HrProcessManager")
  hrProcessesFinalApproval HrProcess[] @relation("HrProcessFinalApprover")
  hrCandidatesCreated HrCandidate[] @relation("HrCandidateCreatedBy")
  hrApplicationsCreated HrProcessCandidate[] @relation("HrApplicationCreatedBy")
  hrNotifications HrNotification[]
  hrApplicationComments HrCandidateComment[] @relation("HrCandidateCommentAuthor")
  hrAuditLogs HrAuditLog[] @relation("HrAuditActor")
  onboardingsAsEmployee Onboarding[] @relation("OnboardingEmployee")
  onboardingsAsManager Onboarding[] @relation("OnboardingManager")
  onboardingsAsHrOwner Onboarding[] @relation("OnboardingHrOwner")
  completedOnboardingItems OnboardingItem[] @relation("OnboardingCompletedBy")
  createdOnboardingTemplates OnboardingTemplate[] @relation("OnboardingTemplateCreatedBy")
  mentoredOnboardingTemplateSteps OnboardingTemplateStep[] @relation("OnboardingTemplateMentor")
  mentoredOnboardingItems OnboardingItem[] @relation("OnboardingMentor")
  hrConfirmedOnboardingItems OnboardingItem[] @relation("OnboardingHrConfirmedBy")
  managerConfirmedOnboardingItems OnboardingItem[] @relation("OnboardingManagerConfirmedBy")

  @@index([managerId])
  @@index([teamId])
  @@index([hrAddon])
  @@index([adminAddon])
}

model OrgPosition {
  id          String   @id @default(cuid())
  title       String
  description String?
  parentId    String?
  kind        OrgNodeKind @default(POSITION)
  teamId      String?
  tier        OrgPositionTier @default(STAFF)
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    OrgPosition? @relation("OrgPositionTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  OrgPosition[] @relation("OrgPositionTree")
  team      Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  links     OrgPositionLink[]
  assignees OrgPositionAssignment[]
  templates OnboardingTemplate[]
  onboardings Onboarding[]

  @@index([parentId])
  @@index([parentId, order])
  @@index([kind])
  @@index([teamId])
  @@index([order])
  @@index([tier])
  @@index([tier, order])
  @@index([isActive])
}

model OrgPositionAssignment {
  id         String   @id @default(cuid())
  positionId String
  userId     String
  createdAt  DateTime @default(now())

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([positionId, userId])
  @@index([userId])
}

model OrgPositionLink {
  id         String   @id @default(cuid())
  positionId String
  label      String
  description String?
  url        String
  type       OrgLinkType @default(POSITION_INSTRUCTION)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  position OrgPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@index([positionId])
  @@index([positionId, type])
  @@index([type])
  @@index([order])
}

model OrgGlobalLink {
  id          String      @id @default(cuid())
  label       String
  description String?
  url         String
  type        OrgLinkType @default(GLOBAL_INSTRUCTION)
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([type])
  @@index([order])
}

model OnboardingTemplate {
  id          String   @id @default(cuid())
  positionId  String   @unique
  title       String?
  description String?
  isActive    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  position   OrgPosition             @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdBy  User?                   @relation("OnboardingTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  steps      OnboardingTemplateStep[]
  onboardings Onboarding[]

  @@index([isActive])
}

model OnboardingTemplateStep {
  id                          String              @id @default(cuid())
  templateId                  String
  title                       String
  description                 String?
  ownerType                   OnboardingItemOwner @default(SHARED)
  dueOffsetDays               Int?
  mentorId                    String?
  hrConfirmationRequired      Boolean             @default(true)
  managerConfirmationRequired Boolean             @default(true)
  links                       Json?
  order                       Int                 @default(0)
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  template OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  mentor   User?              @relation("OnboardingTemplateMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  items    OnboardingItem[]   @relation("OnboardingTemplateStepItems")

  @@index([templateId, order])
  @@index([mentorId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ActivityType {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, name])
  @@index([teamId])
  @@index([isActive])
}

model DailyReport {
  id            String   @id @default(cuid())
  userId        String
  dateIso       String
  employeeEmail String
  employeeName  String
  teamName      String
  position      String?
  week          Int
  month         Int
  year          Int
  totalMinutes  Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id])
  activities DailyReportActivity[]

  @@unique([userId, dateIso])
  @@index([dateIso])
  @@index([employeeEmail])
  @@index([employeeEmail, dateIso])
  @@index([teamName])
  @@index([teamName, dateIso])
  @@index([position])
  @@index([position, dateIso])
}

model DailyReportActivity {
  id        String   @id @default(cuid())
  reportId  String
  type      String
  desc      String
  minutes   Int
  createdAt DateTime @default(now())

  report DailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([type])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  priority    TaskPriority @default(MED)
  status      TaskStatus   @default(OPEN)
  delegatorId String
  assigneeId  String
  teamId      String?
  delegatedAt DateTime     @default(now())
  dueDate     DateTime?
  forApprovalAt DateTime?
  approvedAt  DateTime?
  cancelledAt DateTime?
  returnedCount Int @default(0)
  employeeComment String?
  adminComment String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  delegator   User         @relation("TaskDelegator", fields: [delegatorId], references: [id])
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  team        Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  comments    TaskComment[]
  events      TaskEvent[]

  @@index([assigneeId])
  @@index([delegatorId])
  @@index([status])
  @@index([priority])
  @@index([delegatedAt])
  @@index([dueDate])
  @@index([assigneeId, status])
  @@index([assigneeId, delegatedAt])
  @@index([teamId, delegatedAt])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id])
  author    User     @relation(fields: [authorId], references: [id])
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  action    String
  actorId   String?
  actorEmail String
  actorName String
  comment   String?
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([createdAt])
  @@index([action])
}

model Absence {
  id         String        @id @default(cuid())
  employeeId String
  approverId String?
  type       AbsenceType
  status     AbsenceStatus @default(PENDING)
  dateFrom   DateTime
  dateTo     DateTime
  days       Int
  comment    String?
  overlapWarning Boolean @default(false)
  approvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  employee   User          @relation("EmployeeAbsences", fields: [employeeId], references: [id])
  approver   User?         @relation("ApproverAbsences", fields: [approverId], references: [id])
  events     AbsenceEvent[]

  @@index([employeeId])
  @@index([status])
  @@index([type])
  @@index([dateFrom])
  @@index([dateTo])
  @@index([employeeId, status, dateFrom, dateTo])
  @@index([status, dateFrom, dateTo])
}

model AbsenceEvent {
  id        String   @id @default(cuid())
  absenceId String
  action    String
  actorId   String?
  actorEmail String
  actorName String
  comment   String?
  createdAt DateTime @default(now())

  absence   Absence  @relation(fields: [absenceId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([absenceId])
  @@index([createdAt])
  @@index([action])
}

model PerformanceEvaluation {
  id            String           @id @default(cuid())
  employeeId    String
  managerId     String
  periodStart   DateTime
  periodEnd     DateTime
  periodLabel   String
  status        EvaluationStatus @default(OPEN)
  locked        Boolean          @default(false)
  lockedAt      DateTime?
  lockedById    String?
  unlockOverride Boolean         @default(false)
  closedAt      DateTime?

  personalScore     Float?
  goalsScore        Float?
  finalScore        Float?
  managerFinalComment String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employee      User     @relation("EmployeeEvaluations", fields: [employeeId], references: [id])
  manager       User     @relation("ManagerEvaluations", fields: [managerId], references: [id])
  lockedBy      User?    @relation("LockedByEvaluations", fields: [lockedById], references: [id])
  goals         PerformanceGoal[]
  personalItems PerformancePersonalItem[]
  logs          PerformanceLog[]

  @@index([employeeId])
  @@index([managerId])
  @@index([status])
  @@index([employeeId, status])
  @@index([employeeId, periodEnd])
  @@index([managerId, periodEnd])
  @@index([periodEnd])
}

model PerformanceGoal {
  id              String  @id @default(cuid())
  evaluationId    String
  title           String
  description     String?
  weight          Float
  employeeScore   Float?
  employeeComment String?
  managerScore    Float?
  managerComment  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evaluation      PerformanceEvaluation @relation(fields: [evaluationId], references: [id])
  logs            PerformanceLog[]

  @@index([evaluationId])
}

model PerformanceQuestion {
  id          String   @id @default(cuid())
  qNo         Int      @unique
  area        String
  description String
  scale       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  personalItems PerformancePersonalItem[]
}

model PerformancePersonalItem {
  id              String  @id @default(cuid())
  evaluationId    String
  questionId      String
  qNo             Int
  area            String
  description     String
  scale           String
  managerRating   Float?
  managerComment  String?
  updatedAt       DateTime @updatedAt

  evaluation      PerformanceEvaluation @relation(fields: [evaluationId], references: [id])
  question        PerformanceQuestion   @relation(fields: [questionId], references: [id])

  @@index([evaluationId])
  @@index([qNo])
}

model PerformanceLog {
  id           String   @id @default(cuid())
  evaluationId String
  goalId       String?
  actorId      String?
  actorEmail   String
  action       String
  field        String?
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())

  evaluation   PerformanceEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  goal         PerformanceGoal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  actor        User?                 @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([evaluationId])
  @@index([createdAt])
  @@index([action])
}

model HrProcess {
  id                 String          @id @default(cuid())
  teamId             String?
  positionTitle      String
  requestType        String?
  requestedHeadcount Int             @default(1)
  priority           HrPriority      @default(MED)
  reason             String
  note               String?
  status             HrProcessStatus @default(OPEN)
  openedById         String
  managerId          String?
  finalApproverId    String?
  desiredStartDate   DateTime?
  superiorComment    String?
  superiorDecidedAt  DateTime?
  adPublishedAt      DateTime?
  adChannel          String?
  openedAt           DateTime        @default(now())
  closedAt           DateTime?
  cancelledAt        DateTime?
  archivedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  team          Team?               @relation(fields: [teamId], references: [id], onDelete: SetNull)
  openedBy      User                @relation("HrProcessOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  manager       User?               @relation("HrProcessManager", fields: [managerId], references: [id], onDelete: SetNull)
  finalApprover User?               @relation("HrProcessFinalApprover", fields: [finalApproverId], references: [id], onDelete: SetNull)
  candidates    HrProcessCandidate[]
  notifications HrNotification[]
  auditLogs     HrAuditLog[]
  onboardings   Onboarding[]

  @@index([teamId, status])
  @@index([managerId, status])
  @@index([finalApproverId, status])
  @@index([status, openedAt])
}

model HrCandidate {
  id               String   @id @default(cuid())
  fullName         String
  email            String?
  phone            String?
  linkedIn         String?
  source           String?
  cvDriveUrl       String?
  talentPoolTag    String?
  lastContactAt    DateTime?
  latestCvFileName String?
  latestCvMimeType String?
  latestCvSizeBytes Int?
  latestCvUploadedAt DateTime?
  latestCvData     Bytes?
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy    User?                @relation("HrCandidateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  applications HrProcessCandidate[]
  auditLogs    HrAuditLog[]
  onboardings  Onboarding[]

  @@index([fullName])
  @@index([email])
  @@index([phone])
  @@index([talentPoolTag])
  @@index([updatedAt])
}

model HrProcessCandidate {
  id                     String            @id @default(cuid())
  processId              String
  candidateId            String
  createdById            String?
  status                 HrCandidateStatus @default(NEW_APPLICANT)
  source                 String?
  appliedAt              DateTime          @default(now())
  initialContactAt       DateTime?
  hrComment              String?
  firstRoundComment      String?
  screeningResult        String?
  managerComment         String?
  finalComment           String?
  interviewScheduledAt   DateTime?
  secondRoundCompletedAt DateTime?
  finalDecisionAt        DateTime?
  archivedAt             DateTime?
  cancelledAt            DateTime?
  closedReason           String?
  nextAction             String?
  managerProposedSlots   Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  process       HrProcess           @relation(fields: [processId], references: [id], onDelete: Cascade)
  candidate     HrCandidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy     User?               @relation("HrApplicationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  comments      HrCandidateComment[]
  notifications HrNotification[]
  auditLogs     HrAuditLog[]

  @@unique([processId, candidateId])
  @@index([processId, status])
  @@index([candidateId, status])
  @@index([appliedAt])
}

model Onboarding {
  id                  String           @id @default(cuid())
  processId           String?
  candidateId         String?
  employeeId          String?
  positionId          String?
  templateId          String?
  teamId              String?
  managerId           String?
  hrOwnerId           String?
  startDate           DateTime?
  status              OnboardingStatus @default(PLANNED)
  note                String?
  jobDescriptionUrl   String?
  workInstructionsUrl String?
  onboardingDocsUrl   String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  process     HrProcess?        @relation(fields: [processId], references: [id], onDelete: SetNull)
  candidate   HrCandidate?      @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  employee    User?             @relation("OnboardingEmployee", fields: [employeeId], references: [id], onDelete: SetNull)
  position    OrgPosition?      @relation(fields: [positionId], references: [id], onDelete: SetNull)
  template    OnboardingTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  team        Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  manager     User?             @relation("OnboardingManager", fields: [managerId], references: [id], onDelete: SetNull)
  hrOwner     User?             @relation("OnboardingHrOwner", fields: [hrOwnerId], references: [id], onDelete: SetNull)
  items       OnboardingItem[]

  @@index([processId])
  @@index([candidateId])
  @@index([employeeId, status])
  @@index([positionId, status])
  @@index([templateId])
  @@index([managerId, status])
  @@index([hrOwnerId, status])
  @@index([teamId, status])
}

model OnboardingItem {
  id            String              @id @default(cuid())
  onboardingId  String
  templateStepId String?
  title         String
  description   String?
  ownerType     OnboardingItemOwner @default(SHARED)
  driveUrl      String?
  links         Json?
  dueDate       DateTime?
  mentorId      String?
  hrConfirmationRequired Boolean @default(false)
  managerConfirmationRequired Boolean @default(false)
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  completedById String?
  hrConfirmedAt DateTime?
  hrConfirmedById String?
  managerConfirmedAt DateTime?
  managerConfirmedById String?
  order         Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  onboarding         Onboarding               @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  templateStep       OnboardingTemplateStep?  @relation("OnboardingTemplateStepItems", fields: [templateStepId], references: [id], onDelete: SetNull)
  mentor             User?                    @relation("OnboardingMentor", fields: [mentorId], references: [id], onDelete: SetNull)
  completedBy        User?                    @relation("OnboardingCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  hrConfirmedBy      User?                    @relation("OnboardingHrConfirmedBy", fields: [hrConfirmedById], references: [id], onDelete: SetNull)
  managerConfirmedBy User?                    @relation("OnboardingManagerConfirmedBy", fields: [managerConfirmedById], references: [id], onDelete: SetNull)

  @@index([onboardingId, order])
  @@index([templateStepId])
  @@index([ownerType, isCompleted])
  @@index([mentorId])
  @@index([dueDate])
}

model HrCandidateComment {
  id                 String   @id @default(cuid())
  processCandidateId String
  actorId            String?
  stage              String
  body               String
  createdAt          DateTime @default(now())

  processCandidate HrProcessCandidate @relation(fields: [processCandidateId], references: [id], onDelete: Cascade)
  actor            User?              @relation("HrCandidateCommentAuthor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([processCandidateId, createdAt])
}

model HrNotification {
  id                 String   @id @default(cuid())
  userId             String
  processId          String?
  processCandidateId String?
  type               String
  title              String
  body               String?
  href               String?
  isRead             Boolean  @default(false)
  createdAt          DateTime @default(now())
  readAt             DateTime?

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  process          HrProcess?          @relation(fields: [processId], references: [id], onDelete: Cascade)
  processCandidate HrProcessCandidate? @relation(fields: [processCandidateId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([processId])
  @@index([processCandidateId])
}

model HrAuditLog {
  id                 String   @id @default(cuid())
  processId          String?
  processCandidateId String?
  candidateId        String?
  actorId            String?
  action             String
  field              String?
  oldValue           String?
  newValue           String?
  comment            String?
  createdAt          DateTime @default(now())

  process          HrProcess?          @relation(fields: [processId], references: [id], onDelete: Cascade)
  processCandidate HrProcessCandidate? @relation(fields: [processCandidateId], references: [id], onDelete: Cascade)
  candidate        HrCandidate?        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  actor            User?               @relation("HrAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([processId, createdAt])
  @@index([processCandidateId, createdAt])
  @@index([candidateId, createdAt])
  @@index([actorId, createdAt])
  @@index([action])
}

model ExternalCalendarEvent {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  calendarId    String
  googleEventId String
  status        String   @default("ACTIVE")
  lastSyncedAt  DateTime @default(now())
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([entityType, entityId, calendarId])
  @@index([entityType, entityId])
  @@index([calendarId])
  @@index([status, lastSyncedAt])
}

model NotificationDelivery {
  id                String    @id @default(cuid())
  channel           String
  provider          String    @default("GOOGLE_WORKSPACE")
  entityType        String
  entityId          String
  recipientEmail    String
  subject           String
  status            String    @default("PENDING")
  dedupeKey         String    @unique
  providerMessageId String?
  scheduledAt       DateTime  @default(now())
  sentAt            DateTime?
  failedAt          DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([entityType, entityId])
  @@index([recipientEmail, createdAt])
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackupSnapshot {
  id         String   @id @default(cuid())
  filename   String
  storageKey String   @unique
  source     String
  runKey     String?  @unique
  sizeBytes  Int
  manifestJson Json?
  zipData    Bytes?
  completedAt DateTime?
  failedAt   DateTime?
  errorMessage String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
}
